{% extends "layout.twig" %}
{% set active_page = 'dashboard' %}
{% block title %}Dashboard{% endblock %}

{% block head %}
<style>
.anwesenheit-card {
    border-radius: 14px; border: 2px solid var(--border);
    background: #fff; transition: border-color 0.15s;
}
.anwesenheit-card.status-anwesend  { border-color: #10b981; background: #f0fdf4; }
.anwesenheit-card.status-abwesend  { border-color: #f87171; background: #fef2f2; }
.anwesenheit-card.status-abgeholt  { border-color: #10b981; background: #f0fdf4; }
.status-dot {
    width:10px; height:10px; border-radius:50%; flex-shrink:0;
}
.dot-grau    { background:#cbd5e1; }
.dot-gruen   { background:#10b981; }
.dot-rot     { background:#f87171; }
.dot-blau    { background:#60a5fa; }
.quick-btn { font-size:0.78rem; padding:0.3rem 0.7rem; border-radius:8px; font-weight:500; white-space:nowrap; }
.recent-entry-card { transition: box-shadow 0.15s; }
.recent-entry-card:hover { box-shadow: 0 3px 12px rgba(0,0,0,0.08); }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid" style="max-width: 1200px;">

    <!-- Header -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            {% set stunde = "now"|date("H") %}
            <h1 class="h3 fw-bold mb-1">
                {{ stunde < 12 ? "Guten Morgen" : (stunde < 18 ? "Guten Tag" : "Guten Abend") }} 👋
            </h1>
            {% set wt = heute|date("w")|number_format(0) %}
            <p class="text-muted mb-0">
                {{ {0:'Sonntag',1:'Montag',2:'Dienstag',3:'Mittwoch',4:'Donnerstag',5:'Freitag',6:'Samstag'}[wt] }},
                {{ heute|date("d.m.Y") }}
            </p>
        </div>
        {% if session_rolle == 'admin' %}
        <a href="{{ base_path }}/kinder/neu" class="btn btn-sage btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Kind hinzufügen
        </a>
        {% endif %}
    </div>

    <!-- Geburtstags-Reminder -->
    {% if geburtstage|length > 0 %}
    <div class="card mb-4 p-3" style="border-color: var(--warm); background: var(--warm-light);">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span style="font-size:1.2rem;">🎂</span>
            <span class="fw-semibold" style="color:#92400e;">Bevorstehende Geburtstage</span>
        </div>
        <div class="d-flex flex-wrap gap-2">
            {% for gb in geburtstage %}
            <a href="{{ base_path }}/kinder/{{ gb.id }}" class="text-decoration-none">
                <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 bg-white" style="border:1px solid var(--warm);">
                    <span>{{ gb.diff_tage == 0 ? '🎉' : '🎈' }}</span>
                    <div>
                        <div class="fw-semibold text-dark" style="font-size:0.875rem;">{{ gb.vorname }}</div>
                        <small style="color:#92400e;">
                            {% if gb.diff_tage == 0 %}Heute! · wird {{ gb.wird_jahre }} J.
                            {% elseif gb.diff_tage == 1 %}Morgen · wird {{ gb.wird_jahre }} J.
                            {% else %}in {{ gb.diff_tage }} Tagen · wird {{ gb.wird_jahre }} J.{% endif %}
                        </small>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- Offene Unfälle Hinweis -->
    {% if offene_unfaelle|length > 0 %}
    <div class="card mb-4 p-3" style="border-color:#f59e0b;background:#fffbeb;">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span style="font-size:1.2rem;">⚠️</span>
            <span class="fw-semibold" style="color:#92400e;">{{ offene_unfaelle|length }} unvollständige{{ offene_unfaelle|length == 1 ? 'r Unfall' : ' Unfälle' }}</span>
            <a href="{{ base_path }}/unfaelle?status=entwurf" class="btn btn-sm btn-warning ms-auto">Alle anzeigen</a>
        </div>
        <div class="d-flex flex-wrap gap-2">
            {% for u in offene_unfaelle %}
            <a href="{{ base_path }}/kinder/{{ u.kind_id }}/unfaelle/{{ u.id }}/bearbeiten" class="text-decoration-none">
                <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 bg-white" style="border:1px solid #f59e0b;">
                    <i class="bi bi-exclamation-circle-fill" style="color:#d97706;"></i>
                    <div>
                        <div class="fw-semibold text-dark" style="font-size:0.875rem;">{{ u.vorname }} {{ u.nachname }}</div>
                        <small style="color:#92400e;">{{ u.datum|date("d.m.Y") }} · Entwurf</small>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% if kinder|length > 0 %}

    <!-- === ANWESENHEIT HEUTE === -->
    <div class="mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h6 fw-bold mb-0 text-uppercase text-muted" style="letter-spacing:.05em;">
                <i class="bi bi-calendar-check me-1"></i>Heute anwesend
            </h2>
            <small class="text-muted">
                {% set anwesend_count = 0 %}
                {% for k in kinder %}{% if anwesenheit_heute[k.id] is defined and not anwesenheit_heute[k.id].abwesend %}{% set anwesend_count = anwesend_count + 1 %}{% endif %}{% endfor %}
                {{ anwesend_count }} / {{ kinder|length }}
            </small>
        </div>
        <div class="row g-3">
            {% for kind in kinder %}
            {% set a = anwesenheit_heute[kind.id] ?? null %}
            {% if a and a.abwesend %}
                {% set status = 'abwesend' %}
            {% elseif a and a.ankunft and a.abholung %}
                {% set status = 'abgeholt' %}
            {% elseif a and a.ankunft %}
                {% set status = 'anwesend' %}
            {% else %}
                {% set status = 'offen' %}
            {% endif %}

            <div class="col-12 col-sm-6 col-lg-4">
                <div class="anwesenheit-card p-3 status-{{ status }}">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <!-- Avatar -->
                        {% if kind.foto_pfad %}
                        <img src="{{ base_path }}/uploads/{{ kind.foto_pfad }}" class="avatar" style="width:40px;height:40px;">
                        {% else %}
                        <div class="avatar-placeholder" style="width:40px;height:40px;font-size:0.85rem;">
                            {{ kind.vorname|first }}{{ kind.nachname|first }}
                        </div>
                        {% endif %}
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold" style="font-size:0.9rem;">{{ kind.vorname }}</div>
                            <div class="d-flex align-items-center gap-1">
                                {% if status == 'offen' %}
                                    <span class="status-dot dot-grau"></span>
                                    <small class="text-muted">Noch nicht erfasst</small>
                                {% elseif status == 'anwesend' %}
                                    <span class="status-dot dot-gruen"></span>
                                    <small class="text-success fw-medium">Anwesend seit {{ a.ankunft|slice(0,5) }}</small>
                                {% elseif status == 'abgeholt' %}
                                    <span class="status-dot dot-blau"></span>
                                    <small class="text-primary fw-medium">{{ a.ankunft|slice(0,5) }} – {{ a.abholung|slice(0,5) }}</small>
                                {% elseif status == 'abwesend' %}
                                    <span class="status-dot dot-rot"></span>
                                    <small class="text-danger fw-medium">Abwesend</small>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <!-- Aktions-Buttons -->
                    <div class="d-flex gap-1 flex-wrap">
                        {% if status == 'offen' %}
                            <form method="post" action="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/schnell" class="d-contents">
                                <input type="hidden" name="action" value="einchecken">
                                <input type="hidden" name="redirect" value="{{ base_path }}/">
                                <button class="quick-btn btn btn-success text-white border-0 flex-grow-1">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Angekommen
                                </button>
                            </form>
                            <form method="post" action="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/schnell" class="d-contents">
                                <input type="hidden" name="action" value="abwesend">
                                <input type="hidden" name="redirect" value="{{ base_path }}/">
                                <button class="quick-btn btn btn-outline-danger">
                                    <i class="bi bi-x-circle me-1"></i>Abwesend
                                </button>
                            </form>

                        {% elseif status == 'anwesend' %}
                            <form method="post" action="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/schnell" class="d-contents">
                                <input type="hidden" name="action" value="auschecken">
                                <input type="hidden" name="redirect" value="{{ base_path }}/">
                                <button class="quick-btn btn btn-primary text-white border-0 flex-grow-1">
                                    <i class="bi bi-box-arrow-right me-1"></i>Abgeholt
                                </button>
                            </form>
                            <form method="post" action="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/schnell" class="d-contents">
                                <input type="hidden" name="action" value="zuruecksetzen">
                                <input type="hidden" name="redirect" value="{{ base_path }}/">
                                <button class="quick-btn btn btn-outline-secondary" title="Zurücksetzen">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                </button>
                            </form>

                        {% elseif status == 'abgeholt' or status == 'abwesend' %}
                            <a href="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit" class="quick-btn btn btn-outline-secondary flex-grow-1">
                                <i class="bi bi-pencil me-1"></i>Bearbeiten
                            </a>
                            <form method="post" action="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/schnell" class="d-contents">
                                <input type="hidden" name="action" value="zuruecksetzen">
                                <input type="hidden" name="redirect" value="{{ base_path }}/">
                                <button class="quick-btn btn btn-outline-secondary" title="Zurücksetzen">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <!-- === LETZTE TAGEBUCHEINTRÄGE === -->
    {% if recent_entries|length > 0 %}
    <div class="mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h6 fw-bold mb-0 text-uppercase text-muted" style="letter-spacing:.05em;">
                <i class="bi bi-journal-text me-1"></i>Zuletzt im Tagebuch
            </h2>
        </div>
        <div class="row g-2">
            {% for e in recent_entries %}
            <div class="col-12 col-sm-6 col-lg-3">
                <a href="{{ base_path }}/kinder/{{ e.kind_id }}?tab=tagebuch" class="text-decoration-none">
                    <div class="card recent-entry-card p-3 h-100">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            {% if e.foto_pfad %}
                            <img src="{{ base_path }}/uploads/{{ e.foto_pfad }}" style="width:22px;height:22px;border-radius:6px;object-fit:cover;">
                            {% else %}
                            <div style="width:22px;height:22px;border-radius:6px;background:var(--sage-light);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;color:var(--sage-dark);">{{ e.vorname|first }}</div>
                            {% endif %}
                            <span class="text-muted" style="font-size:0.75rem;">{{ e.vorname }} · {{ e.datum|date("d.m.") }}</span>
                            {% if e.stimmung %}
                            <span style="font-size:0.85rem;">{{ ['','😢','😕','😐','😊','😄'][e.stimmung] }}</span>
                            {% endif %}
                        </div>
                        {% if e.titel %}
                        <div class="fw-semibold text-dark" style="font-size:0.85rem;">{{ e.titel }}</div>
                        {% endif %}
                        <p class="text-muted mb-0" style="font-size:0.8rem;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">{{ e.text }}</p>
                    </div>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- === KINDER ÜBERSICHT === -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h6 fw-bold mb-0 text-uppercase text-muted" style="letter-spacing:.05em;">
            <i class="bi bi-people-fill me-1"></i>Kinder
        </h2>
        <a href="{{ base_path }}/kinder" class="btn btn-sm btn-outline-secondary">Alle anzeigen</a>
    </div>
    <div class="row g-3">
        {% for kind in kinder %}
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3">
                <div class="d-flex align-items-center gap-3 mb-3">
                    {% if kind.foto_pfad %}
                    <img src="{{ base_path }}/uploads/{{ kind.foto_pfad }}" alt="{{ kind.vorname }}" class="avatar">
                    {% else %}
                    <div class="avatar-placeholder">{{ kind.vorname|first }}{{ kind.nachname|first }}</div>
                    {% endif %}
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-semibold text-dark">{{ kind.vorname }} {{ kind.nachname }}</div>
                        {% set alter_tage = (((heute|date("U")) - (kind.geburtsdatum|date("U"))) / 86400)|round(0,'floor') %}
                        {% set alter_jahre = (alter_tage / 365)|round(0,'floor') %}
                        {% set alter_monate = ((alter_tage - alter_jahre * 365) / 30)|round(0,'floor') %}
                        <small class="text-muted">{{ alter_jahre }} J. {{ alter_monate }} M.</small>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="{{ base_path }}/kinder/{{ kind.id }}?tab=tagebuch" class="quick-btn btn btn-light flex-grow-1">
                        <i class="bi bi-journal-plus me-1"></i>Tagebuch
                    </a>
                    <a href="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit" class="quick-btn btn btn-light flex-grow-1">
                        <i class="bi bi-calendar-check me-1"></i>Anwesenheit
                    </a>
                    {% if session_rolle == 'admin' %}
                    <a href="{{ base_path }}/kinder/{{ kind.id }}/unfaelle/neu" class="quick-btn btn btn-light px-2" title="Unfall erfassen" style="color:#d97706;">
                        <i class="bi bi-exclamation-triangle"></i>
                    </a>
                    {% endif %}
                    <a href="{{ base_path }}/kinder/{{ kind.id }}" class="quick-btn btn btn-light px-2" title="Profil">
                        <i class="bi bi-person"></i>
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    {% else %}
    <!-- Leerer Zustand -->
    <div class="card text-center py-5 px-3">
        <div class="mx-auto mb-3" style="width:64px;height:64px;border-radius:18px;background:var(--sage-light);display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-people fs-2" style="color:var(--sage)"></i>
        </div>
        <h5 class="fw-semibold">Noch keine Kinder angelegt</h5>
        <p class="text-muted mb-3">Lege dein erstes Kind an, um loszulegen.</p>
        <div><a href="{{ base_path }}/kinder/neu" class="btn btn-sage"><i class="bi bi-plus-lg me-1"></i>Kind hinzufügen</a></div>
    </div>
    {% endif %}

</div>
{% endblock %}
