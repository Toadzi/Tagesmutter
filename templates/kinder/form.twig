{% extends "layout.twig" %}
{% set active_page = 'kinder' %}

{% block title %}{{ is_new ? 'Kind anlegen' : 'Kind bearbeiten' }}{% endblock %}

{% block content %}
<div class="container-fluid" style="max-width: 800px;">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ base_path }}/kinder" class="text-decoration-none">Kinder</a></li>
            <li class="breadcrumb-item active">{{ is_new ? 'Neues Kind' : kind.vorname ~ ' bearbeiten' }}</li>
        </ol>
    </nav>

    <h1 class="h3 fw-bold mb-4">{{ is_new ? 'Kind anlegen' : 'Kind bearbeiten' }}</h1>

    <form method="post" action="{{ base_path ~ (is_new ? '/kinder/neu' : '/kinder/' ~ kind.id ~ '/bearbeiten') }}">
        <!-- Persönliche Daten -->
        <div class="card mb-4">
            <div class="card-header py-3">
                <h6 class="fw-semibold mb-0">Persönliche Daten</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label" for="vorname">Vorname *</label>
                        <input type="text" name="vorname" id="vorname" class="form-control" value="{{ kind.vorname ?? '' }}" required>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="nachname">Nachname *</label>
                        <input type="text" name="nachname" id="nachname" class="form-control" value="{{ kind.nachname ?? '' }}" required>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="geburtsdatum">Geburtsdatum *</label>
                        <input type="date" name="geburtsdatum" id="geburtsdatum" class="form-control" value="{{ kind.geburtsdatum ?? '' }}" required>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="geschlecht">Geschlecht</label>
                        <select name="geschlecht" id="geschlecht" class="form-select">
                            <option value="">— wählen —</option>
                            <option value="m" {{ (kind.geschlecht ?? '') == 'm' ? 'selected' : '' }}>männlich</option>
                            <option value="w" {{ (kind.geschlecht ?? '') == 'w' ? 'selected' : '' }}>weiblich</option>
                            <option value="d" {{ (kind.geschlecht ?? '') == 'd' ? 'selected' : '' }}>divers</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="muttersprache">Muttersprache</label>
                        <input type="text" name="muttersprache" id="muttersprache" class="form-control" value="{{ kind.muttersprache ?? '' }}">
                    </div>
                </div>
            </div>
        </div>

        <!-- Adresse -->
        <div class="card mb-4">
            <div class="card-header py-3">
                <h6 class="fw-semibold mb-0">Adresse</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="adresse">Straße</label>
                        <input type="text" name="adresse" id="adresse" class="form-control" value="{{ kind.adresse ?? '' }}">
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label" for="plz">PLZ</label>
                        <input type="text" name="plz" id="plz" class="form-control" value="{{ kind.plz ?? '' }}">
                    </div>
                    <div class="col-sm-8">
                        <label class="form-label" for="ort">Ort</label>
                        <input type="text" name="ort" id="ort" class="form-control" value="{{ kind.ort ?? '' }}">
                    </div>
                </div>
            </div>
        </div>

        <!-- Betreuung -->
        <div class="card mb-4">
            <div class="card-header py-3">
                <h6 class="fw-semibold mb-0">Betreuung</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label" for="betreuung_start">Beginn</label>
                        <input type="date" name="betreuung_start" id="betreuung_start" class="form-control" value="{{ kind.betreuung_start ?? '' }}">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="betreuung_ende">Ende</label>
                        <input type="date" name="betreuung_ende" id="betreuung_ende" class="form-control" value="{{ kind.betreuung_ende ?? '' }}">
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="betreuungszeiten">Betreuungszeiten</label>
                        <input type="text" name="betreuungszeiten" id="betreuungszeiten" class="form-control" value="{{ kind.betreuungszeiten ?? '' }}" placeholder="z.B. Mo-Fr 8:00-15:00">
                    </div>
                </div>
            </div>
        </div>

        <!-- Gesundheit -->
        <div class="card mb-4">
            <div class="card-header py-3">
                <h6 class="fw-semibold mb-0">Gesundheit</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="allergien">Allergien / Unverträglichkeiten</label>
                        <textarea name="allergien" id="allergien" rows="2" class="form-control">{{ kind.allergien ?? '' }}</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="medikamente">Medikamente</label>
                        <textarea name="medikamente" id="medikamente" rows="2" class="form-control">{{ kind.medikamente ?? '' }}</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="besonderheiten">Besonderheiten</label>
                        <textarea name="besonderheiten" id="besonderheiten" rows="2" class="form-control">{{ kind.besonderheiten ?? '' }}</textarea>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="arzt_name">Kinderarzt</label>
                        <input type="text" name="arzt_name" id="arzt_name" class="form-control" value="{{ kind.arzt_name ?? '' }}">
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="arzt_telefon">Telefon Arzt</label>
                        <input type="tel" name="arzt_telefon" id="arzt_telefon" class="form-control" value="{{ kind.arzt_telefon ?? '' }}">
                    </div>
                </div>
            </div>
        </div>

        <!-- Einstellungen -->
        <div class="card mb-4">
            <div class="card-header py-3">
                <h6 class="fw-semibold mb-0">Einstellungen</h6>
            </div>
            <div class="card-body">
                <div class="form-check mb-2">
                    <input type="checkbox" name="foto_freigabe" value="1" class="form-check-input" id="foto_freigabe" {{ (kind.foto_freigabe ?? 0) ? 'checked' : '' }}>
                    <label class="form-check-label" for="foto_freigabe">Fotofreigabe erteilt (DSGVO)</label>
                </div>
                {% if not is_new %}
                <div class="form-check">
                    <input type="checkbox" name="aktiv" value="1" class="form-check-input" id="aktiv" {{ (kind.aktiv ?? 1) ? 'checked' : '' }}>
                    <label class="form-check-label" for="aktiv">Kind ist aktiv</label>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Buttons -->
        <div class="d-flex gap-2 mb-4">
            <button type="submit" class="btn btn-sage">
                {{ is_new ? 'Kind anlegen' : 'Änderungen speichern' }}
            </button>
            <a href="{{ is_new ? '/kinder' : '/kinder/' ~ kind.id }}" class="btn btn-outline-secondary">Abbrechen</a>
        </div>
    </form>
</div>
{% endblock %}
