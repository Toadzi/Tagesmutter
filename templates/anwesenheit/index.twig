{% extends "layout.twig" %}
{% set active_page = 'kinder' %}

{% block title %}Anwesenheit — {{ kind.vorname }}{% endblock %}

{% block content %}
<div class="container-fluid" style="max-width: 1000px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ base_path }}/kinder/{{ kind.id }}" class="text-decoration-none">{{ kind.vorname }}</a></li>
            <li class="breadcrumb-item active">Anwesenheit</li>
        </ol>
    </nav>

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <h1 class="h3 fw-bold mb-0">Anwesenheit — {{ kind.vorname }}</h1>
        <div class="d-flex gap-2">
            <a href="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/pdf?monat={{ monat }}&jahr={{ jahr }}" class="btn btn-warm btn-sm">
                <i class="bi bi-file-pdf me-1"></i> PDF
            </a>
            <a href="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/csv?monat={{ monat }}&jahr={{ jahr }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-filetype-csv me-1"></i> CSV
            </a>
        </div>
    </div>

    <!-- Month Navigation -->
    {% set prev_monat = monat == 1 ? 12 : monat - 1 %}
    {% set prev_jahr = monat == 1 ? jahr - 1 : jahr %}
    {% set next_monat = monat == 12 ? 1 : monat + 1 %}
    {% set next_jahr = monat == 12 ? jahr + 1 : jahr %}
    {% set monatsnamen = ['','Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'] %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit?monat={{ prev_monat }}&jahr={{ prev_jahr }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chevron-left"></i>
        </a>
        <h5 class="fw-semibold mb-0">{{ monatsnamen[monat] }} {{ jahr }}</h5>
        <a href="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit?monat={{ next_monat }}&jahr={{ next_jahr }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chevron-right"></i>
        </a>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-4">
            <div class="card p-3 text-center">
                <div class="fs-4 fw-bold" style="color: var(--sage)">{{ anwesend_tage }}</div>
                <small class="text-muted">Anwesend</small>
            </div>
        </div>
        <div class="col-4">
            <div class="card p-3 text-center">
                <div class="fs-4 fw-bold text-danger">{{ abwesent_tage }}</div>
                <small class="text-muted">Abwesend</small>
            </div>
        </div>
        <div class="col-4">
            <div class="card p-3 text-center">
                <div class="fs-4 fw-bold" style="color: var(--warm)">{{ gesamt_stunden }}h</div>
                <small class="text-muted">Stunden</small>
            </div>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="card">
        <div class="card-body p-0">
            <form method="post" action="{{ base_path }}/kinder/{{ kind.id }}/anwesenheit/speichern">
                <input type="hidden" name="monat" value="{{ monat }}">
                <input type="hidden" name="jahr" value="{{ jahr }}">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:100px">Datum</th>
                                <th style="width:50px">Tag</th>
                                <th style="width:120px">Ankunft</th>
                                <th style="width:120px">Abholung</th>
                                <th style="width:50px" class="text-center">Abw.</th>
                                <th style="width:120px">Grund</th>
                                <th>Notiz</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set wochentage = ['So','Mo','Di','Mi','Do','Fr','Sa'] %}
                            {% for tag in 1..tage_im_monat %}
                                {% set datum = "%04d-%02d-%02d"|format(jahr, monat, tag) %}
                                {% set wt = datum|date("w") %}
                                {% set eintrag = anwesenheit[datum] ?? {} %}
                                {% set isWeekend = wt == 0 or wt == 6 %}
                                <tr class="{{ isWeekend ? 'table-secondary' : '' }}">
                                    <td class="small">{{ datum|date("d.m.") }}</td>
                                    <td class="small {{ isWeekend ? 'fw-semibold' : '' }}">{{ wochentage[wt] }}</td>
                                    <td>
                                        <input type="time" name="tage[{{ datum }}][ankunft]" class="form-control form-control-sm" value="{{ eintrag.ankunft ?? '' }}">
                                    </td>
                                    <td>
                                        <input type="time" name="tage[{{ datum }}][abholung]" class="form-control form-control-sm" value="{{ eintrag.abholung ?? '' }}">
                                    </td>
                                    <td class="text-center">
                                        <input type="checkbox" name="tage[{{ datum }}][abwesend]" value="1" class="form-check-input" {{ (eintrag.abwesend ?? 0) ? 'checked' : '' }}>
                                    </td>
                                    <td>
                                        <select name="tage[{{ datum }}][grund]" class="form-select form-select-sm">
                                            <option value="">—</option>
                                            <option value="krank" {{ (eintrag.abwesenheitsgrund ?? '') == 'krank' ? 'selected' : '' }}>Krank</option>
                                            <option value="urlaub" {{ (eintrag.abwesenheitsgrund ?? '') == 'urlaub' ? 'selected' : '' }}>Urlaub</option>
                                            <option value="sonstiges" {{ (eintrag.abwesenheitsgrund ?? '') == 'sonstiges' ? 'selected' : '' }}>Sonstig</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="text" name="tage[{{ datum }}][notiz]" class="form-control form-control-sm" value="{{ eintrag.notiz ?? '' }}" placeholder="...">
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="p-3 border-top">
                    <button type="submit" class="btn btn-sage">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
