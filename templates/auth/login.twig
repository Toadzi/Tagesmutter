<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anmelden — {{ app_settings.app_name ?? 'MiniStep' }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root { --sage: #557d58; --sage-dark: #365038; }
        body { background: linear-gradient(135deg, #f4f7f4 0%, #e3ebe3 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { width: 100%; max-width: 420px; border-radius: 20px; border: 1px solid #e0e8e0; box-shadow: 0 8px 32px rgba(85,125,88,0.12); }
        .login-logo { width: 60px; height: 60px; border-radius: 16px; background: linear-gradient(135deg, #557d58, #365038); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: white; margin: 0 auto 1rem; }
        .btn-sage { background: var(--sage); color: #fff; border: none; }
        .btn-sage:hover { background: var(--sage-dark); color: #fff; }
        .form-control:focus { border-color: var(--sage); box-shadow: 0 0 0 0.2rem rgba(85,125,88,.2); }
    </style>
</head>
<body>
    <div class="login-card bg-white p-4 p-sm-5">
        <div class="text-center mb-4">
            <div class="login-logo"><i class="bi bi-house-heart"></i></div>
            <h1 class="h4 fw-bold mb-1">{{ app_settings.app_name ?? 'MiniStep' }}</h1>
            <p class="text-muted small">Bitte melde dich an</p>
        </div>

        {% if fehler %}
        <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>{{ fehler }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}

        <form method="post" action="{{ base_path }}/login">
            <div class="mb-3">
                <label class="form-label" for="benutzername">Benutzername</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input type="text" name="benutzername" id="benutzername" class="form-control" placeholder="benutzername" autofocus autocomplete="username" required>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label" for="passwort">Passwort</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input type="password" name="passwort" id="passwort" class="form-control" placeholder="••••••••" autocomplete="current-password" required>
                </div>
            </div>
            <button type="submit" class="btn btn-sage w-100 py-2">
                <i class="bi bi-box-arrow-in-right me-1"></i> Anmelden
            </button>
        </form>

        <p class="text-center text-muted small mt-4 mb-0">
            <i class="bi bi-shield-lock me-1"></i>Nur lokal zugänglich
        </p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
