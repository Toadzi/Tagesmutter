{% extends "layout.twig" %}
{% set active_page = 'unfaelle' %}
{% block title %}Unfallbuch {{ kind.vorname }}{% endblock %}

{% block content %}
<div class="container-fluid" style="max-width:900px;">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ base_path }}/kinder/{{ kind.id }}" class="text-decoration-none">{{ kind.vorname }}</a></li>
            <li class="breadcrumb-item active">Unfallbuch</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Unfallbuch</h1>
            <p class="text-muted mb-0">{{ kind.vorname }} {{ kind.nachname }} · {{ unfaelle|length }} {{ unfaelle|length == 1 ? 'Eintrag' : 'Einträge' }}</p>
        </div>
        {% if session_rolle == 'admin' %}
        <a href="{{ base_path }}/kinder/{{ kind.id }}/unfaelle/neu" class="btn btn-warm">
            <i class="bi bi-plus-lg me-1"></i>Unfall erfassen
        </a>
        {% endif %}
    </div>

    {% if unfaelle|length > 0 %}
    <div class="card">
        <div class="list-group list-group-flush">
            {% for u in unfaelle %}
            {% set sc = u.status == 'abgeschlossen' ? 'success' : (u.status == 'gemeldet' ? 'primary' : 'warning') %}
            {% set sl = u.status == 'abgeschlossen' ? 'Abgeschlossen' : (u.status == 'gemeldet' ? 'Gemeldet' : 'Entwurf') %}
            <div class="list-group-item px-3 py-3 d-flex align-items-center gap-3">
                <div style="width:10px;height:10px;border-radius:50%;flex-shrink:0;background:{{ u.status == 'abgeschlossen' ? '#10b981' : (u.status == 'gemeldet' ? '#3b82f6' : '#f59e0b') }};"></div>
                <div class="flex-grow-1 min-w-0">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="fw-semibold text-dark">{{ u.datum|date("d.m.Y") }}</span>
                        {% if u.uhrzeit %}<small class="text-muted">{{ u.uhrzeit }} Uhr</small>{% endif %}
                        {% if u.ort %}<small class="text-muted">· {{ u.ort }}</small>{% endif %}
                        <span class="badge bg-{{ sc }}-subtle text-{{ sc }}-emphasis border border-{{ sc }}-subtle">{{ sl }}</span>
                        {% if u.unfallkasse_gemeldet %}
                        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><i class="bi bi-check2-circle me-1"></i>Unfallkasse</span>
                        {% endif %}
                    </div>
                    {% if u.einzelheiten %}
                    <p class="text-muted mb-0 mt-1" style="font-size:0.8rem;overflow:hidden;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;">{{ u.einzelheiten }}</p>
                    {% endif %}
                </div>
                <div class="d-flex gap-1 flex-shrink-0">
                    <a href="{{ base_path }}/kinder/{{ kind.id }}/unfaelle/{{ u.id }}" class="btn btn-sm btn-light" title="Anzeigen"><i class="bi bi-eye"></i></a>
                    {% if session_rolle == 'admin' %}
                    <a href="{{ base_path }}/kinder/{{ kind.id }}/unfaelle/{{ u.id }}/bearbeiten" class="btn btn-sm btn-light" title="Bearbeiten"><i class="bi bi-pencil"></i></a>
                    {% endif %}
                    <a href="{{ base_path }}/kinder/{{ kind.id }}/unfaelle/{{ u.id }}/pdf" class="btn btn-sm btn-light" title="PDF" target="_blank"><i class="bi bi-file-pdf"></i></a>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="card text-center py-5">
        <div class="mx-auto mb-3" style="width:48px;height:48px;border-radius:14px;background:#f0fdf4;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-shield-check" style="color:#10b981;font-size:1.3rem;"></i>
        </div>
        <p class="text-muted mb-2">Noch keine Unfälle erfasst.</p>
        {% if session_rolle == 'admin' %}
        <div><a href="{{ base_path }}/kinder/{{ kind.id }}/unfaelle/neu" class="btn btn-warm btn-sm"><i class="bi bi-plus-lg me-1"></i>Unfall erfassen</a></div>
        {% endif %}
    </div>
    {% endif %}

</div>
{% endblock %}
