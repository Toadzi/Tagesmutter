{% extends "layout.twig" %}
{% set active_page = 'unfaelle' %}
{% block title %}Unfallbuch{% endblock %}

{% block content %}
<div class="container-fluid" style="max-width:1200px;">

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Unfallbuch</h1>
            <p class="text-muted mb-0">{{ unfaelle|length }} {{ unfaelle|length == 1 ? 'Eintrag' : 'Einträge' }}</p>
        </div>
    </div>

    {# Filter #}
    <div class="card mb-4 p-3">
        <form method="get" action="{{ base_path }}/unfaelle" class="row g-2 align-items-end">
            <div class="col-12 col-sm-6 col-md-3">
                <label class="form-label small fw-semibold">Kind</label>
                <select name="kind_id" class="form-select form-select-sm">
                    <option value="">Alle Kinder</option>
                    {% for k in kinder %}
                    <option value="{{ k.id }}" {{ filter.kind_id == k.id ? 'selected' : '' }}>{{ k.vorname }} {{ k.nachname }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-12 col-sm-6 col-md-2">
                <label class="form-label small fw-semibold">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Alle</option>
                    <option value="entwurf"      {{ filter.status == 'entwurf'      ? 'selected' : '' }}>Entwurf</option>
                    <option value="abgeschlossen" {{ filter.status == 'abgeschlossen' ? 'selected' : '' }}>Abgeschlossen</option>
                    <option value="gemeldet"     {{ filter.status == 'gemeldet'     ? 'selected' : '' }}>Gemeldet</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-semibold">Von</label>
                <input type="date" name="von" value="{{ filter.von ?? '' }}" class="form-control form-control-sm">
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small fw-semibold">Bis</label>
                <input type="date" name="bis" value="{{ filter.bis ?? '' }}" class="form-control form-control-sm">
            </div>
            <div class="col-12 col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-sage btn-sm flex-grow-1">Filtern</button>
                <a href="{{ base_path }}/unfaelle" class="btn btn-outline-secondary btn-sm">Zurücksetzen</a>
            </div>
        </form>
    </div>

    {% if unfaelle|length > 0 %}
    <div class="card">
        <div class="list-group list-group-flush">
            {% for u in unfaelle %}
            {% set status_color = u.status == 'abgeschlossen' ? 'success' : (u.status == 'gemeldet' ? 'primary' : 'warning') %}
            {% set status_label = u.status == 'abgeschlossen' ? 'Abgeschlossen' : (u.status == 'gemeldet' ? 'Gemeldet' : 'Entwurf') %}
            <div class="list-group-item px-3 py-3">
                <div class="d-flex align-items-center gap-3">
                    {% if u.foto_pfad %}
                    <img src="{{ base_path }}/uploads/{{ u.foto_pfad }}" class="avatar" style="width:40px;height:40px;">
                    {% else %}
                    <div class="avatar-placeholder" style="width:40px;height:40px;font-size:0.8rem;">{{ u.vorname|first }}{{ u.nachname|first }}</div>
                    {% endif %}
                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="fw-semibold text-dark">{{ u.vorname }} {{ u.nachname }}</span>
                            <span class="badge bg-{{ status_color }}-subtle text-{{ status_color }}-emphasis border border-{{ status_color }}-subtle">{{ status_label }}</span>
                            {% if u.unfallkasse_gemeldet %}
                            <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><i class="bi bi-check2-circle me-1"></i>Unfallkasse</span>
                            {% endif %}
                        </div>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>{{ u.datum|date("d.m.Y") }}
                            {% if u.uhrzeit %} · {{ u.uhrzeit }} Uhr{% endif %}
                            {% if u.ort %} · {{ u.ort }}{% endif %}
                        </small>
                        {% if u.einzelheiten %}
                        <div class="text-muted mt-1" style="font-size:0.8rem;overflow:hidden;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;">{{ u.einzelheiten }}</div>
                        {% endif %}
                    </div>
                    <div class="d-flex gap-1 flex-shrink-0">
                        <a href="{{ base_path }}/kinder/{{ u.kind_id }}/unfaelle/{{ u.id }}" class="btn btn-sm btn-light" title="Anzeigen"><i class="bi bi-eye"></i></a>
                        <a href="{{ base_path }}/kinder/{{ u.kind_id }}/unfaelle/{{ u.id }}/bearbeiten" class="btn btn-sm btn-light" title="Bearbeiten"><i class="bi bi-pencil"></i></a>
                        <a href="{{ base_path }}/kinder/{{ u.kind_id }}/unfaelle/{{ u.id }}/pdf" class="btn btn-sm btn-light" title="PDF" target="_blank"><i class="bi bi-file-pdf"></i></a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="card text-center py-5">
        <div class="mx-auto mb-3" style="width:48px;height:48px;border-radius:14px;background:#fef3c7;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-shield-check" style="color:#d97706;font-size:1.3rem;"></i>
        </div>
        <p class="text-muted mb-0">Keine Unfälle gefunden.</p>
    </div>
    {% endif %}

</div>
{% endblock %}
